<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox  fx:id="handleCategorias" prefHeight="500" prefWidth="450" spacing="15" style="-fx-padding: 20; -fx-background-color: #F5F5F5;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.bootcamp.controllers.CategoriasController">

    <Label style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #212121;" text="Categoria" />

    <HBox spacing="10">
        <TextField fx:id="descriptorField" prefHeight="25.0" prefWidth="426.0" promptText="Descrição" />
    </HBox>

    <HBox spacing="10">
        <ComboBox fx:id="TipoCombo" prefWidth="200" promptText="Tipo" />
        <Button onAction="#handleAdicionar" prefWidth="100" style="-fx-background-color: #F44336; -fx-text-fill: white; -fx-font-weight: bold;" text="Adicionar" />
        <Button onAction="#handleApagar" prefWidth="100" style="-fx-background-color: #616161; -fx-text-fill: white; -fx-font-weight: bold;" text="Apagar" />
    </HBox>

    <Label fx:id="messageLabel" style="-fx-text-fill: red;" />

    <TableView fx:id="categoryTable" prefHeight="300">
        <columns>
            <TableColumn fx:id="descriptionCol" prefWidth="212.0" text="Descrição" />
            <TableColumn fx:id="TipoCol" prefWidth="197.0" text="Tipo" />
        </columns>
    </TableView>

</VBox>

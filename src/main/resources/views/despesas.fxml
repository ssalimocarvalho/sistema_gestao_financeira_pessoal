<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" style="-fx-padding: 20; -fx-background-color: #F5F5F5;"
      prefWidth="450" prefHeight="500"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.bootcamp.controllers.DespesasController">

    <Label text="Despesas" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #212121;"/>

    <HBox spacing="10">
        <TextField fx:id="descriptorField" promptText="Descrição" prefWidth="200"/>
        <TextField fx:id="valorField" promptText="Valor (MT)" prefWidth="100"/>
        <DatePicker fx:id="dataPicker" promptText="Data"/>
    </HBox>

    <HBox spacing="10">
        <ComboBox fx:id="categoryCombo" promptText="Categoria" prefWidth="200"/>
        <Button text="Adicionar" onAction="#handleAdicionar"
                style="-fx-background-color: #F44336; -fx-text-fill: white; -fx-font-weight: bold;"
                prefWidth="100"/>
        <Button text="Apagar" onAction="#handleApagar"
                style="-fx-background-color: #616161; -fx-text-fill: white; -fx-font-weight: bold;"
                prefWidth="100"/>
    </HBox>

    <Label fx:id="messageLabel" style="-fx-text-fill: red;"/>

    <TableView fx:id="expensesTable" prefHeight="300">
        <columns>
            <TableColumn fx:id="dataCol" text="Data" prefWidth="90"/>
            <TableColumn fx:id="descriptionCol" text="Descrição" prefWidth="150"/>
            <TableColumn fx:id="categoryCol" text="Categoria" prefWidth="100"/>
            <TableColumn fx:id="amountCol" text="Valor (MT)" prefWidth="100"/>
        </columns>
    </TableView>

</VBox>
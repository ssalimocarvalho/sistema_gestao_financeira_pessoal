<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" style="-fx-padding: 20; -fx-background-color: #F5F5F5;"
      prefWidth="450" prefHeight="500"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.salimocarvalho.controllers.RelatoriosController">

    <Label text="Relatórios" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #212121;"/>

    <HBox spacing="10">
        <DatePicker fx:id="dataIniciopicker" promptText="Data Início"/>
        <DatePicker fx:id="dataFimPicker" promptText="Data Fim"/>
        <Button text="Filtrar" onAction="#handleFiltrar"
                style="-fx-background-color: #1565C0; -fx-text-fill: white; -fx-font-weight: bold;"
                prefWidth="80"/>
    </HBox>

    <HBox spacing="10">
        <VBox style="-fx-background-color: #E8F5E9; -fx-padding: 12; -fx-background-radius: 8;" prefWidth="130">
            <Label text="Total Incomes" style="-fx-font-size: 11; -fx-text-fill: #1B5E20;"/>
            <Label fx:id="totalIncomesLabel" text="0.00 MT"
                   style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #2E7D32;"/>
        </VBox>
        <VBox style="-fx-background-color: #FFEBEE; -fx-padding: 12; -fx-background-radius: 8;" prefWidth="130">
            <Label text="Total Expenses" style="-fx-font-size: 11; -fx-text-fill: #B71C1C;"/>
            <Label fx:id="totalExpensesLabel" text="0.00 MT"
                   style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #C62828;"/>
        </VBox>
        <VBox style="-fx-background-color: #E3F2FD; -fx-padding: 12; -fx-background-radius: 8;" prefWidth="130">
            <Label text="Balance" style="-fx-font-size: 11; -fx-text-fill: #0D47A1;"/>
            <Label fx:id="balanceLabel" text="0.00 MT"
                   style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1565C0;"/>
        </VBox>
    </HBox>

    <Label text="Transaction on Period"
           style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #616161;"/>

    <TableView fx:id="reportTable" prefHeight="220">
        <columns>
            <TableColumn fx:id="dateCol" text="Data" prefWidth="90"/>
            <TableColumn fx:id="descriptionCol" text="Descrição" prefWidth="130"/>
            <TableColumn fx:id="typeCol" text="Tipo" prefWidth="80"/>
            <TableColumn fx:id="amountCol" text="Valor (MT)" prefWidth="100"/>
        </columns>
    </TableView>

    <Button text="Exportar CSV" onAction="#handleExportarCSV"
            style="-fx-background-color: #FF9800; -fx-text-fill: white; -fx-font-weight: bold;"
            prefWidth="150"/>

</VBox>